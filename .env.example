# URL base de la API (incluye el prefijo /api del backend NestJS)
VITE_API_BASE_URL=https://exhototo-backend.vercel.app/api

# Ruta de login relativa a VITE_API_BASE_URL
VITE_AUTH_LOGIN_PATH=/auth/login

# Recuperación de contraseña (NestJS /api/auth/*; rutas opcionales si difieren)
# VITE_AUTH_FORGOT_PATH=/auth/forgot-password
# VITE_AUTH_VALIDATE_RECOVERY_PATH=/auth/validate-recovery-code
# VITE_AUTH_RESET_PASSWORD_PATH=/auth/reset-password
